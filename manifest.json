{
  "manifest_version": 3,
  "name": "Browsersky AI",
  "version": "1.0.0",
  "description": "A browser-based AI assistant that analyzes web pages and answers questions using page context",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "tabGroups"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Browsersky AI",
    "default_icon": {
      "16": "icons/Logo (1).png",
      "32": "icons/Logo (1).png",
      "48": "icons/Logo (1).png",
      "128": "icons/Logo (1).png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      },
      "description": "Open Browsersky AI side panel"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:3000/*"]
  },
  "icons": {
    "16": "icons/Logo (1).png",
    "32": "icons/Logo (1).png",
    "48": "icons/Logo (1).png",
    "128": "icons/Logo (1).png"
  }
}

